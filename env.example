# ═══════════════════════════════════════════
# JARVIS v3.0 — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# ─── API KEYS (REQUIRED) ───
GROQ_API_KEY=your_groq_api_key_here

# ─── TTS (OPTIONAL) ───
# English (kept same by default)
TTS_RATE_EN=+10%
TTS_PITCH_EN=+1Hz
# Hindi (faster by default)
TTS_RATE_HINDI=+20%
TTS_PITCH_HINDI=+1Hz

